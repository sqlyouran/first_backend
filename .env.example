# ===== WanderChina Backend Environment Variables =====
# Copy this file to .env and fill in real values.
# .env is gitignored and will NOT be committed.

# AI (DashScope / 通义千问) — required for AI chat feature
DASHSCOPE_API_KEY=

# MySQL — connection settings
# Local dev defaults: DB_HOST=localhost, DB_USER=root, DB_PASSWORD=123456
# RDS demo/prod: set DB_HOST to your RDS endpoint, DB_USE_SSL=true
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wanderchina
DB_USER=root
DB_PASSWORD=123456
DB_USE_SSL=false
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# Exchange Rate API (https://www.exchangerate-api.com) — required for exchange rate feature
EXCHANGE_RATE_API_KEY=

# JWT Secret — MUST be a random string of at least 32 characters in production
# Generate with: openssl rand -base64 48
JWT_SECRET=dev-secret-key-change-in-production-min-32-chars!!

# CORS allowed origins — comma-separated list of allowed frontend domains
# Dev: http://localhost:3000
# Prod: https://wanderchina.com,https://www.wanderchina.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
